<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.bambooforest.mapper.UserMapper">

    <insert id="insertUser" parameterType="com.example.bambooforest.model.Users">
        INSERT INTO users (
            username,
            password,
            nickname,
            status
        ) VALUES (
                     #{username},
                     #{password},
                     #{nickname},
                     'Y'
                 )
    </insert>

    <select id="findByUsername" resultType="com.example.bambooforest.model.Users">
        SELECT username, password FROM users
        WHERE username = #{username}
    </select>

    <select id="findByNickname" resultType="com.example.bambooforest.model.Users">
        SELECT nickname FROM users
        WHERE nickname = #{nickname}
    </select>



</mapper>